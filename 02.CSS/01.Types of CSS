<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Types of CSS</title>

    <!-- External CSS -->
    <link rel="stylesheet" href="styles.css">

    <!-- Internal CSS -->
    <style>
        h2 {
            color: blue;
        }
    </style>
</head>
<body>

    <!-- Inline CSS -->
    <h1 style="color: red;">This is Inline CSS</h1>

    <!-- Internal CSS -->
    <h2>This is Internal CSS</h2>

    <!-- External CSS -->
    <p>This is External CSS</p>

</body>
</html>
